// Tavolo — gestionale ospitalità
// Schema multi-tenant: Organization (gruppo) -> Venue (locale) -> risorse operative.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Identità ────────────────────────────────────────────────────────────────

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  passwordHash     String?
  image            String?
  createdAt        DateTime          @default(now())
  orgMemberships   OrgMembership[]
  venueMemberships VenueMembership[]
  sessions         Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Multi-tenant ────────────────────────────────────────────────────────────

model Organization {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  plan      Plan            @default(STARTER)
  createdAt DateTime        @default(now())
  venues    Venue[]
  members   OrgMembership[]
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      OrgRole  @default(OWNER)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_membership")
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING
}

model Venue {
  id                    String    @id @default(cuid())
  orgId                 String
  name                  String
  slug                  String
  kind                  VenueKind @default(RESTAURANT)
  timezone              String    @default("Europe/Rome")
  currency              String    @default("EUR")
  address               String?
  city                  String?
  country               String?
  phone                 String?
  email                 String?
  coverImage            String?
  active                Boolean   @default(true)
  depositThreshold      Int       @default(8)
  depositPerPersonCents Int       @default(2000)
  wifiPortalLogoUrl     String?
  wifiPortalAccent      String?   @db.VarChar(9)
  wifiPortalWelcome     String?   @db.VarChar(500)
  wifiPortalLegal       String?   @db.VarChar(2000)
  wifiAutoCouponEnabled Boolean   @default(false)
  wifiAutoCouponPercent Int       @default(10)
  wifiAutoCouponDays    Int       @default(30)
  wifiSetupAt           DateTime?
  calendarToken         String?   @unique
  googlePlaceId         String?
  brandLogoUrl          String?
  brandAccent           String?   @db.VarChar(9)
  brandFootnote         String?   @db.VarChar(280)
  createdAt             DateTime  @default(now())

  org               Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members           VenueMembership[]
  rooms             Room[]
  tables            Table[]
  shifts            Shift[]
  bookings          Booking[]
  guests            Guest[]
  experiences       Experience[]
  campaigns         Campaign[]
  payments          Payment[]
  blocks            TableBlock[]
  decor             FloorDecor[]
  templates         MessageTemplate[]
  surveys           Survey[]
  waitlist          WaitlistEntry[]
  menuCategories    MenuCategory[]
  menuItems         MenuItem[]
  orders            Order[]
  wifiLeads         WifiLead[]
  wifiSessions      WifiSession[]
  consentLogs       ConsentLog[]
  coupons           Coupon[]
  couponRedemptions CouponRedemption[]
  reviewLinks       ReviewLink[]
  reviewLinkClicks  ReviewLinkClick[]
  messageLogs       MessageLog[]
  workflows         AutomationWorkflow[]
  chatSessions      ChatSession[]
  callLogs          CallLog[]
  missedCalls       MissedCall[]
  costEntries       CostEntry[]
  staffShifts       StaffShift[]
  menuItemCosts     MenuItemCost[]
  menuScans         MenuScan[]
  connectors        Connector[]
  giftCards         GiftCard[]
  posConnectors     POSConnector[]
  reviews           Review[]
  notifications     Notification[]

  @@unique([orgId, slug])
}

enum VenueKind {
  RESTAURANT
  BEACH_CLUB
  BAR
  HOTEL_RESTAURANT
  PRIVATE_CLUB
}

model VenueMembership {
  id        String    @id @default(cuid())
  userId    String
  venueId   String
  role      StaffRole @default(RECEPTION)
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@map("venue_membership")
}

enum StaffRole {
  MANAGER
  RECEPTION
  WAITER
  MARKETING
  READ_ONLY
}

// ─── Sala e tavoli ───────────────────────────────────────────────────────────

model Room {
  id       String       @id @default(cuid())
  venueId  String
  name     String
  width    Int          @default(1200) // canvas px
  height   Int          @default(800)
  ordering Int          @default(0)
  venue    Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables   Table[]
  decor    FloorDecor[]
}

model Table {
  id         String     @id @default(cuid())
  venueId    String
  roomId     String?
  label      String // es. "T7", "Beach 12"
  seats      Int        @default(2)
  shape      TableShape @default(ROUND)
  posX       Int        @default(0)
  posY       Int        @default(0)
  width      Int?
  height     Int?
  rotation   Int        @default(0)
  combinable Boolean    @default(true)
  active     Boolean    @default(true)

  venue    Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  room     Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  bookings Booking[]
  blocks   TableBlock[]

  @@unique([venueId, label])
}

enum TableShape {
  ROUND
  SQUARE
  RECT
  BOOTH
  LOUNGE
}

model FloorDecor {
  id        String    @id @default(cuid())
  venueId   String
  roomId    String?
  kind      DecorKind
  label     String?
  posX      Int       @default(0)
  posY      Int       @default(0)
  width     Int       @default(80)
  height    Int       @default(80)
  rotation  Int       @default(0)
  color     String?
  createdAt DateTime  @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  room  Room? @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([venueId])
}

enum DecorKind {
  PLANT
  SOFA
  ARMCHAIR
  BAR
  COUNTER
  KITCHEN
  DJ_BOOTH
  STAGE
  COLUMN
  DIVIDER
  DOOR
  WINDOW
  ENTRANCE
  RESTROOM
  POOL
  STAIRS
  RUG
  LAMP
  LABEL
}

model TableBlock {
  id       String   @id @default(cuid())
  venueId  String
  tableId  String
  startsAt DateTime
  endsAt   DateTime
  reason   String?

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model Shift {
  id          String  @id @default(cuid())
  venueId     String
  name        String // "Pranzo", "Cena", "Aperitivo"
  weekday     Int // 0 = domenica
  startMinute Int // 0..1439
  endMinute   Int
  capacity    Int     @default(80)
  slotMinutes Int     @default(15)
  active      Boolean @default(true)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Guest {
  id             String      @id @default(cuid())
  venueId        String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  birthday       DateTime?
  language       String      @default("it")
  loyaltyTier    LoyaltyTier @default(NEW)
  totalVisits    Int         @default(0)
  totalSpend     Decimal     @default(0) @db.Decimal(12, 2)
  noShowCount    Int         @default(0)
  lastVisitAt    DateTime?
  preferences    Json? // diete, posti preferiti
  allergies      String?
  privateNotes   String? // visibile solo a manager
  tags           String[]    @default([])
  marketingOptIn Boolean     @default(false)
  loyaltyPoints  Int         @default(0)
  blocked        Boolean     @default(false)
  blockedReason  String?     @db.VarChar(400)
  blockedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  venue               Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  payments            Payment[]
  orders              Order[]
  wifiLeads           WifiLead[]
  consentLogs         ConsentLog[]
  coupons             Coupon[]
  couponRedemptions   CouponRedemption[]
  messageLogs         MessageLog[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([venueId, email])
  @@index([venueId, phone])
  @@index([venueId, lastName])
}

enum LoyaltyTier {
  NEW
  REGULAR
  VIP
  AMBASSADOR
}

// ─── Prenotazioni ────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  reference     String        @unique @default(cuid())
  venueId       String
  guestId       String?
  tableId       String?
  partySize     Int
  startsAt      DateTime
  durationMin   Int           @default(105)
  status        BookingStatus @default(CONFIRMED)
  source        BookingSource @default(WIDGET)
  occasion      Occasion?
  notes         String?
  internalNotes String?
  depositCents  Int           @default(0)
  depositStatus DepositStatus @default(NONE)
  isGroup       Boolean       @default(false)
  eventType     String?       @db.VarChar(60)
  budgetCents   Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  arrivedAt     DateTime?
  seatedAt      DateTime?
  closedAt      DateTime?

  venue      Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest      Guest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)
  table      Table?             @relation(fields: [tableId], references: [id], onDelete: SetNull)
  payments   Payment[]
  events     BookingEvent[]
  voiceDraft VoiceBookingDraft?
  preorder   BookingPreorder?

  @@index([venueId, startsAt])
  @@index([venueId, status])
}

model BookingEvent {
  id        String           @id @default(cuid())
  bookingId String
  kind      BookingEventKind
  message   String?
  meta      Json?
  actorId   String?
  createdAt DateTime         @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

enum BookingEventKind {
  CREATED
  STATUS_CHANGED
  TABLE_CHANGED
  TIME_CHANGED
  PARTY_CHANGED
  NOTES_UPDATED
  DEPOSIT_PAID
  DEPOSIT_FAILED
  REMINDER_SENT
  CONFIRMATION_SENT
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  PENDING
  ARRIVED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WIDGET
  PHONE
  WALK_IN
  GOOGLE
  SOCIAL
  CONCIERGE
  EVENT
}

enum Occasion {
  BIRTHDAY
  ANNIVERSARY
  BUSINESS
  DATE
  CELEBRATION
  OTHER
}

enum DepositStatus {
  NONE
  HELD
  CAPTURED
  REFUNDED
  FAILED
}

// ─── Esperienze / Eventi ─────────────────────────────────────────────────────

model Experience {
  id          String   @id @default(cuid())
  venueId     String
  title       String
  slug        String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(40)
  priceCents  Int      @default(0)
  ticketUrl   String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  venue   Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@unique([venueId, slug])
}

model Ticket {
  id           String       @id @default(cuid())
  experienceId String
  buyerName    String
  buyerEmail   String
  quantity     Int          @default(1)
  totalCents   Int          @default(0)
  status       TicketStatus @default(PAID)
  checkedInAt  DateTime?
  checkedInBy  String?
  createdAt    DateTime     @default(now())

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

enum TicketStatus {
  PAID
  REFUNDED
  CANCELLED
  CHECKED_IN
}

// ─── Marketing ───────────────────────────────────────────────────────────────

model Campaign {
  id          String          @id @default(cuid())
  venueId     String
  name        String
  channel     CampaignChannel @default(EMAIL)
  segment     Json? // filtro CRM
  subject     String?
  body        String?
  scheduledAt DateTime?
  status      CampaignStatus  @default(DRAFT)
  sentCount   Int             @default(0)
  openedCount Int             @default(0)
  bookedCount Int             @default(0)
  createdAt   DateTime        @default(now())

  venue       Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  messageLogs MessageLog[]
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
}

model MessageTemplate {
  id        String           @id @default(cuid())
  venueId   String
  name      String
  channel   CampaignChannel  @default(EMAIL)
  subject   String?
  body      String
  category  TemplateCategory @default(GENERIC)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, name])
  @@index([venueId, category])
}

enum TemplateCategory {
  GENERIC
  WELCOME
  REMINDER
  THANK_YOU
  PROMO
  WIN_BACK
  BIRTHDAY
  ANNIVERSARY
  EVENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  ARCHIVED
}

// ─── Pagamenti ───────────────────────────────────────────────────────────────

model MenuCategory {
  id        String   @id @default(cuid())
  venueId   String
  name      String
  ordering  Int      @default(0)
  menuKey   String   @default("main") // "main" | "lunch" | "dinner" | "tasting" | "events" | custom
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  venue Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  items MenuItem[]

  @@index([venueId, menuKey, ordering])
}

model MenuItem {
  id          String   @id @default(cuid())
  categoryId  String
  venueId     String
  name        String
  description String?
  priceCents  Int      @default(0)
  currency    String   @default("EUR")
  available   Boolean  @default(true)
  ordering    Int      @default(0)
  allergens   String[] @default([])
  dietary     String[] @default([])
  imageUrl    String?
  createdAt   DateTime @default(now())

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  venue      Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([categoryId, ordering])
}

model Order {
  id            String        @id @default(cuid())
  reference     String        @unique @default(cuid())
  venueId       String
  guestId       String?
  kind          OrderKind     @default(TAKEAWAY)
  status        OrderStatus   @default(RECEIVED)
  paymentStatus PaymentStatus @default(PENDING)
  customerName  String
  phone         String
  email         String?
  address       String?
  tableLabel    String?       @db.VarChar(40)
  scheduledAt   DateTime
  totalCents    Int           @default(0)
  currency      String        @default("EUR")
  notes         String?
  stripeId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  preparedAt    DateTime?
  readyAt       DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?

  venue Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest Guest?      @relation(fields: [guestId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([venueId, status, scheduledAt])
}

enum OrderKind {
  TAKEAWAY
  DELIVERY
  TABLE
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  ON_THE_WAY
  COMPLETED
  CANCELLED
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String?
  name       String // snapshot
  priceCents Int
  quantity   Int     @default(1)
  notes      String?

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model WaitlistEntry {
  id                 String         @id @default(cuid())
  venueId            String
  guestId            String?
  guestName          String
  phone              String?
  email              String?
  partySize          Int
  expectedWaitMin    Int            @default(20)
  status             WaitlistStatus @default(WAITING)
  notifiedAt         DateTime?
  seatedAt           DateTime?
  cancelledAt        DateTime?
  position           Int            @default(0)
  notes              String?
  offerToken         String?        @unique
  offerExpiresAt     DateTime?
  offerSentVia       String?        @db.VarChar(20)
  confirmedAt        DateTime?
  convertedBookingId String?
  declinedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, status, createdAt])
}

enum WaitlistStatus {
  WAITING
  OFFERED
  NOTIFIED
  CONFIRMED
  SEATED
  EXPIRED
  DECLINED
  CANCELLED
  NO_SHOW
}

model Survey {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  venueId     String
  bookingId   String?   @unique
  guestId     String?
  sentAt      DateTime  @default(now())
  respondedAt DateTime?

  venue    Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  response SurveyResponse?

  @@index([venueId, sentAt])
}

model SurveyResponse {
  id        String    @id @default(cuid())
  surveyId  String    @unique
  npsScore  Int // 0..10
  sentiment Sentiment
  comment   String?
  recommend Boolean?
  createdAt DateTime  @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

enum Sentiment {
  PROMOTER
  PASSIVE
  DETRACTOR
}

model Payment {
  id              String        @id @default(cuid())
  venueId         String
  bookingId       String?
  guestId         String?
  amountCents     Int
  currency        String        @default("EUR")
  kind            PaymentKind   @default(DEPOSIT)
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?
  createdAt       DateTime      @default(now())
  refundedAt      DateTime?

  venue   Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  guest   Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
}

enum PaymentKind {
  DEPOSIT
  PREAUTH
  TICKET
  REFUND
  PACKAGE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─── Wi-Fi marketing ─────────────────────────────────────────────────────────

model WifiLead {
  id               String   @id @default(cuid())
  venueId          String
  guestId          String?
  name             String
  email            String?
  phone            String?
  source           String? // ssid, ap-mac, table, campaign id
  ipAddress        String?
  userAgent        String?
  consentMarketing Boolean  @default(false)
  consentPrivacy   Boolean  @default(true)
  createdAt        DateTime @default(now())

  venue    Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest    Guest?        @relation(fields: [guestId], references: [id], onDelete: SetNull)
  sessions WifiSession[]

  @@index([venueId, createdAt])
  @@index([venueId, email])
  @@index([venueId, phone])
}

model WifiSession {
  id          String    @id @default(cuid())
  leadId      String
  venueId     String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?
  ipAddress   String?
  userAgent   String?
  deviceType  String? // mobile / desktop / tablet (best-effort)

  lead  WifiLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  venue Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, startedAt])
}

model ConsentLog {
  id        String         @id @default(cuid())
  venueId   String
  guestId   String?
  leadId    String?
  channel   ConsentChannel
  granted   Boolean
  source    String? // wifi / widget / admin / chat / coupon
  ipAddress String?
  userAgent String?
  createdAt DateTime       @default(now())

  venue Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([venueId, channel, createdAt])
  @@index([guestId])
}

enum ConsentChannel {
  EMAIL
  SMS
  WHATSAPP
  MARKETING_GENERAL
  PRIVACY
  PROFILING
}

// ─── Coupon e promozioni ─────────────────────────────────────────────────────

model Coupon {
  id              String         @id @default(cuid())
  venueId         String
  code            String         @unique
  name            String
  description     String?
  kind            CouponKind     @default(PERCENT)
  value           Int            @default(0) // % (0..100) or cents based on kind
  freeItem        String? // for FREE_ITEM kind: item name snapshot
  category        CouponCategory @default(GENERIC)
  status          CouponStatus   @default(ACTIVE)
  validFrom       DateTime?
  validUntil      DateTime?
  maxRedemptions  Int? // total cap
  maxPerGuest     Int            @default(1)
  guestId         String? // when assigned to a specific guest
  segment         Json? // optional segment selector
  redemptionCount Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  venue       Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest       Guest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)
  redemptions CouponRedemption[]

  @@index([venueId, status])
  @@index([venueId, category])
}

enum CouponKind {
  PERCENT
  FIXED
  FREE_ITEM
  MENU_OFFER
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum CouponCategory {
  GENERIC
  BIRTHDAY
  WINBACK
  EVENT
  NEW_CUSTOMER
  WIFI
  REFERRAL
  STAFF
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  venueId     String
  guestId     String?
  bookingId   String?
  orderId     String?
  ticketId    String?
  amountCents Int? // discount applied at redemption
  notes       String?
  redeemedAt  DateTime @default(now())
  redeemedBy  String? // user id of staff member, when manual

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  guest  Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([venueId, redeemedAt])
  @@index([couponId])
}

// ─── Review funnel ────────────────────────────────────────────────────────────

model ReviewLink {
  id        String         @id @default(cuid())
  venueId   String
  platform  ReviewPlatform
  label     String? // optional override
  url       String
  ordering  Int            @default(0)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  venue  Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  clicks ReviewLinkClick[]

  @@index([venueId, active, ordering])
}

enum ReviewPlatform {
  GOOGLE
  TRIPADVISOR
  TRUSTPILOT
  THEFORK
  FACEBOOK
  INSTAGRAM
  YELP
  OTHER
}

model ReviewLinkClick {
  id        String   @id @default(cuid())
  linkId    String
  venueId   String
  surveyId  String?
  npsScore  Int?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  link  ReviewLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  venue Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([venueId, createdAt])
}

// ─── Message log (multi-channel per-recipient delivery audit) ────────────────

model MessageLog {
  id            String         @id @default(cuid())
  venueId       String
  campaignId    String?
  workflowRunId String?
  guestId       String?
  channel       MessageChannel
  toAddress     String // email / phone / wa-number snapshot
  subject       String?
  bodyPreview   String?
  status        MessageStatus  @default(QUEUED)
  providerId    String?
  error         String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  createdAt     DateTime       @default(now())

  venue       Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  campaign    Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  guest       Guest?         @relation(fields: [guestId], references: [id], onDelete: SetNull)
  workflowRun AutomationRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
  @@index([campaignId])
  @@index([guestId, channel])
}

enum MessageChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

// ─── Marketing automation workflows ──────────────────────────────────────────

model AutomationWorkflow {
  id           String            @id @default(cuid())
  venueId      String
  name         String
  description  String?
  trigger      AutomationTrigger
  active       Boolean           @default(false)
  conditions   Json? // segment-style filters (e.g. { tier: ["VIP"], minVisits: 3 })
  actions      Json // [{ kind, params }]
  delayMinutes Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdBy    String?

  venue Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  runs  AutomationRun[]

  @@index([venueId, trigger, active])
}

enum AutomationTrigger {
  BOOKING_CREATED
  BOOKING_COMPLETED
  GUEST_BIRTHDAY
  GUEST_INACTIVE
  COUPON_NOT_USED
  NPS_DETRACTOR
  WIFI_LEAD_CREATED
  ORDER_COMPLETED
  CUSTOM
}

model AutomationRun {
  id         String              @id @default(cuid())
  workflowId String
  venueId    String
  trigger    AutomationTrigger
  status     AutomationRunStatus @default(QUEUED)
  payload    Json? // event payload at trigger time
  result     Json? // counters, errors per action
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime            @default(now())

  workflow    AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  messageLogs MessageLog[]

  @@index([workflowId, createdAt])
  @@index([venueId, createdAt])
}

enum AutomationRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

// ─── Conversational booking (chatbot + voice scaffold) ───────────────────────

model ChatSession {
  id             String     @id @default(cuid())
  venueId        String
  source         ChatSource @default(WEB)
  guestId        String?
  bookingId      String?
  status         ChatStatus @default(OPEN)
  draftPartySize Int?
  draftDate      String? // YYYY-MM-DD captured during the conversation
  draftTime      String? // HH:MM
  draftFirstName String?
  draftLastName  String?
  draftEmail     String?
  draftPhone     String?
  draftNotes     String?
  language       String     @default("it")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  venue    Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([venueId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  text      String
  intent    String? // e.g. "ASK_PARTY_SIZE", "CONFIRM"
  payload   Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

enum ChatRole {
  USER
  BOT
  STAFF
}

enum ChatSource {
  WEB
  WHATSAPP
  SMS
  WIDGET
  VOICE
}

enum ChatStatus {
  OPEN
  CONVERTED
  ABANDONED
  HANDOFF
}

model CallLog {
  id           String        @id @default(cuid())
  venueId      String
  fromNumber   String
  toNumber     String?
  direction    CallDirection @default(INBOUND)
  status       CallStatus    @default(QUEUED)
  recordingUrl String?
  transcript   String?
  durationSec  Int?
  intent       String? // BOOKING / INFO / OTHER
  draftId      String?       @unique
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime      @default(now())

  venue Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  draft VoiceBookingDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  MISSED
  FAILED
}

model VoiceBookingDraft {
  id            String      @id @default(cuid())
  venueId       String
  callerName    String?
  phone         String?
  partySize     Int?
  preferredDate String? // YYYY-MM-DD
  preferredTime String? // HH:MM
  notes         String?
  status        DraftStatus @default(NEW)
  bookingId     String?     @unique
  reviewedBy    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  call    CallLog?
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
}

enum DraftStatus {
  NEW
  CONFIRMED
  REJECTED
}

model MissedCall {
  id             String    @id @default(cuid())
  venueId        String
  fromNumber     String
  attempts       Int       @default(1)
  callbackSentAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

// ─── Controllo economico (food cost, spese, turni) ────────────────────────────

model CostEntry {
  id          String       @id @default(cuid())
  venueId     String
  category    CostCategory
  label       String
  amountCents Int
  currency    String       @default("EUR")
  occurredOn  DateTime // day-resolution
  recurring   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  createdBy   String?

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, occurredOn])
}

enum CostCategory {
  FOOD
  BEVERAGE
  STAFF
  RENT
  UTILITIES
  MARKETING
  SUPPLIES
  OTHER
}

model StaffShift {
  id          String   @id @default(cuid())
  venueId     String
  staffName   String
  role        String?
  date        DateTime // day
  hours       Float    @default(8)
  hourlyCents Int      @default(1200)
  notes       String?
  createdAt   DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, date])
}

model MenuItemCost {
  id         String   @id @default(cuid())
  venueId    String
  menuItemId String   @unique
  costCents  Int      @default(0) // raw food cost per portion
  updatedAt  DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

// ─── Menu Lead Magnet: trattalo come trigger commerciale, non solo lettura ────

model MenuScan {
  id               String         @id @default(cuid())
  venueId          String
  menuKey          String         @default("main")
  source           MenuScanSource @default(QR)
  ipHash           String?
  userAgent        String?
  guestId          String?
  email            String?
  phone            String?
  consentMarketing Boolean        @default(false)
  createdAt        DateTime       @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

enum MenuScanSource {
  QR
  TABLE
  WIDGET
  LINK
}

// ─── Channel Manager (TheFork / Google Reserve / Booking.com / custom) ───────

model Connector {
  id            String          @id @default(cuid())
  venueId       String
  kind          ConnectorKind
  label         String?
  status        ConnectorStatus @default(DRAFT)
  config        Json? // mapping ids, default party size, prefix for reference, etc.
  webhookSecret String? // shared secret for HMAC verification
  externalRef   String? // external account / property id (display only)
  lastSyncAt    DateTime?
  lastError     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  venue  Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  events ConnectorEvent[]

  @@unique([venueId, kind])
  @@index([venueId, status])
}

enum ConnectorKind {
  THEFORK
  GOOGLE_RESERVE
  BOOKING_COM
  OPENTABLE
  CUSTOM
}

enum ConnectorStatus {
  DRAFT
  ACTIVE
  PAUSED
  ERROR
}

model ConnectorEvent {
  id          String               @id @default(cuid())
  connectorId String
  venueId     String
  direction   ConnectorDirection
  kind        String // e.g. "booking.created", "booking.cancelled", "ping"
  status      ConnectorEventStatus @default(RECEIVED)
  payload     Json?
  bookingId   String?
  error       String?
  createdAt   DateTime             @default(now())

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, createdAt])
  @@index([venueId, createdAt])
}

enum ConnectorDirection {
  INBOUND
  OUTBOUND
}

enum ConnectorEventStatus {
  RECEIVED
  PROCESSED
  REJECTED
  FAILED
}

// ─── Loyalty: punti su ogni euro speso, riscatti tracciati ───────────────────

model LoyaltyTransaction {
  id        String         @id @default(cuid())
  guestId   String
  venueId   String
  kind      LoyaltyTxnKind
  points    Int
  reason    String?        @db.VarChar(200)
  bookingId String?
  orderId   String?
  createdBy String?
  createdAt DateTime       @default(now())

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([guestId, createdAt])
}

enum LoyaltyTxnKind {
  EARNED
  REDEEMED
  ADJUSTED
  EXPIRED
}

// ─── Gift cards: vendi una carta regalo, riscatta a porzioni ────────────────

model GiftCard {
  id              String         @id @default(cuid())
  venueId         String
  code            String         @unique
  initialCents    Int
  balanceCents    Int
  currency        String         @default("EUR")
  recipientName   String?
  recipientEmail  String?
  senderName      String?
  message         String?        @db.VarChar(500)
  status          GiftCardStatus @default(ACTIVE)
  expiresAt       DateTime?
  stripePaymentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?

  venue       Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  redemptions GiftCardRedemption[]

  @@index([venueId, status])
}

enum GiftCardStatus {
  PENDING_PAYMENT
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELLED
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String
  amountCents Int
  bookingId   String?
  orderId     String?
  reason      String?  @db.VarChar(200)
  createdBy   String?
  createdAt   DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId, createdAt])
}

// ─── Pre-order: scelta menu al momento della prenotazione ───────────────────

model BookingPreorder {
  id         String         @id @default(cuid())
  bookingId  String         @unique
  status     PreorderStatus @default(DRAFT)
  totalCents Int            @default(0)
  notes      String?        @db.VarChar(500)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  booking Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  items   BookingPreorderItem[]
}

enum PreorderStatus {
  DRAFT
  CONFIRMED
  PREPARED
  CANCELLED
}

model BookingPreorderItem {
  id         String  @id @default(cuid())
  preorderId String
  menuItemId String?
  name       String
  priceCents Int
  quantity   Int     @default(1)
  notes      String? @db.VarChar(200)

  preorder BookingPreorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  @@index([preorderId])
}

// ─── POS integration: ingerisci vendite dal punto cassa ─────────────────────

model POSConnector {
  id            String             @id @default(cuid())
  venueId       String
  kind          POSConnectorKind
  label         String?
  status        POSConnectorStatus @default(DRAFT)
  config        Json?
  webhookSecret String?
  externalRef   String?
  lastSyncAt    DateTime?
  lastError     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  venue  Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  events POSEvent[]

  @@unique([venueId, kind])
  @@index([venueId, status])
}

enum POSConnectorKind {
  SQUARE
  LIGHTSPEED
  SUMUP
  IZETTLE
  TOAST
  CUSTOM
}

enum POSConnectorStatus {
  DRAFT
  ACTIVE
  PAUSED
  ERROR
}

model POSEvent {
  id             String         @id @default(cuid())
  posConnectorId String
  venueId        String
  externalRef    String?
  action         String // sale.created / sale.refunded / ping
  amountCents    Int            @default(0)
  currency       String         @default("EUR")
  payload        Json?
  status         POSEventStatus @default(RECEIVED)
  orderId        String?
  error          String?
  createdAt      DateTime       @default(now())

  connector POSConnector @relation(fields: [posConnectorId], references: [id], onDelete: Cascade)

  @@index([posConnectorId, createdAt])
  @@index([venueId, createdAt])
}

enum POSEventStatus {
  RECEIVED
  PROCESSED
  REJECTED
  FAILED
}

// ─── Notifiche in-app per lo staff ──────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  venueId   String
  kind      NotificationKind
  title     String           @db.VarChar(160)
  body      String?          @db.VarChar(500)
  link      String?          @db.VarChar(300)
  meta      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([venueId, readAt])
}

enum NotificationKind {
  BOOKING_CREATED
  BOOKING_CANCELLED
  NPS_DETRACTOR
  WAITLIST_ACCEPTED
  CONNECTOR_INBOUND
  POS_INBOUND
  AUTOMATION_FAILED
  GIFT_CARD_REDEEMED
  WIFI_LEAD
  CHAT_HANDOFF
  MISSED_CALL
  REVIEW_RECEIVED
}

// ─── Recensioni aggregate (Google + altre piattaforme) ──────────────────────

model Review {
  id           String       @id @default(cuid())
  venueId      String
  source       ReviewSource
  externalRef  String?
  externalUrl  String?
  rating       Int
  authorName   String?      @db.VarChar(120)
  authorAvatar String?
  text         String?      @db.VarChar(2000)
  language     String       @default("it")
  publishedAt  DateTime?
  fetchedAt    DateTime     @default(now())
  createdAt    DateTime     @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, source, externalRef])
  @@index([venueId, publishedAt])
}

enum ReviewSource {
  GOOGLE
  TRIPADVISOR
  FACEBOOK
  YELP
  TRUSTPILOT
  MANUAL
}
